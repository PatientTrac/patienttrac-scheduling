{
  "name": "@patienttrac/clinical-viewer",
  "version": "0.1.0",
  "description": "Shared read-only clinical chart and labs panel for PatientTrac apps",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles.css",
    "./tailwind.preset": "./tailwind.preset.cjs"
  },
  "files": [
    "dist",
    "src/styles.css",
    "tailwind.preset.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.2.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
