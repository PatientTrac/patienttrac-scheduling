{
  "name": "@patienttrac/clinical-viewer",
  "version": "0.1.3",
  "description": "Shared read-only clinical chart and labs panel for PatientTrac apps",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind.preset": "./tailwind.preset.cjs"
  },
  "files": [
    "dist",
    "tailwind.preset.cjs"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles.css -o ./dist/styles.css --minify",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "clsx": "^2.1.1",
    "react-is": "^18.3.1"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2 || ^3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.1.0",
    "typescript": "^5.2.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}